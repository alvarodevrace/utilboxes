---
const { title, description, href, emoji = '🔧' } = Astro.props;
---
<a href={href} class="block p-5 rounded-xl border border-zinc-800 bg-zinc-900 hover:border-indigo-500 hover:bg-zinc-800 transition-all group">
  <div class="text-3xl mb-3">{emoji}</div>
  <h2 class="font-semibold text-white group-hover:text-indigo-400 transition-colors">{title}</h2>
  <p class="mt-1 text-sm text-zinc-400">{description}</p>
</a>
