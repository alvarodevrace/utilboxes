---
const { position = 'top' } = Astro.props;

const labels = {
  top: 'Anuncio superior',
  sidebar: 'Anuncio lateral',
  bottom: 'Anuncio inferior',
};
---
<aside
  class="my-6 min-h-24 rounded-lg border border-dashed border-zinc-800 bg-zinc-900/40 px-4 py-6 text-center text-xs uppercase tracking-wide text-zinc-600"
  aria-label={labels[position] ?? 'Anuncio'}
  data-ad-position={position}
>
  {labels[position] ?? 'Anuncio'}
</aside>
