---
import SEOMeta from './SEOMeta.astro';
import AdSlot from './AdSlot.astro';

const {
  title = 'UtilBoxes 2026 | Herramientas gratis',
  description = 'Herramientas gratis para calcular, generar y resolver tareas de emprendedores y freelancers en Latinoamerica.',
  showTopAd = false,
  showBottomAd = false,
} = Astro.props;

const adsenseClient = 'ca-pub-4782913478347937';
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <SEOMeta {title} {description} />
  <link rel="icon" type="image/png" href="/brand/logo.png" />
  <link rel="apple-touch-icon" href="/brand/logo.png" />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-N9R880WHV1"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-N9R880WHV1');
  </script>
  <script async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`} crossorigin="anonymous"></script>
</head>
<body class="bg-zinc-950 text-zinc-100 min-h-screen">
  <header class="border-b border-zinc-800 bg-zinc-950/90 px-6 py-4">
    <div class="mx-auto flex max-w-6xl flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <a href="/" class="inline-flex items-center gap-3 text-xl font-bold text-white" aria-label="Inicio UtilBoxes">
        <img src="/brand/logo.png" alt="Logo UtilBoxes" class="h-10 w-10 rounded-full object-contain" />
        <span>Util<span class="text-emerald-400">Boxes</span></span>
      </a>
      <nav class="flex flex-wrap gap-4 text-sm text-zinc-400">
        <a href="/herramientas/calculadora-iva" class="hover:text-white">IVA</a>
        <a href="/herramientas/generador-password" class="hover:text-white">Password</a>
        <a href="/herramientas/precio-freelance" class="hover:text-white">Freelance</a>
        <a href="/blog" class="hover:text-white">Blog</a>
      </nav>
    </div>
  </header>
  <main class="max-w-6xl mx-auto px-6 py-10">
    {showTopAd && <AdSlot position="top" />}
    <slot />
    {showBottomAd && <AdSlot position="bottom" />}
  </main>
  <footer class="mt-20 border-t border-zinc-800 px-6 py-6 text-sm text-zinc-500">
    <div class="mx-auto flex max-w-6xl flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <a href="/" class="inline-flex items-center gap-3 font-semibold text-zinc-200" aria-label="Inicio UtilBoxes">
        <img src="/brand/logo.png" alt="Logo UtilBoxes" class="h-10 w-10 rounded-full object-contain" loading="lazy" />
        <span>UtilBoxes 2026</span>
      </a>
      <div class="flex flex-wrap gap-4 sm:justify-end">
        <a href="/blog" class="hover:text-zinc-300">Blog</a>
        <a href="/privacidad" class="hover:text-zinc-300">Privacidad</a>
      </div>
    </div>
  </footer>
</body>
</html>
