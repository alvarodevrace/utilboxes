---
const { title = 'UtilBoxes — Herramientas gratuitas para LatAm', description = 'Calculadoras, generadores y utilidades web gratuitas para emprendedores y freelancers de Latinoamérica.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="sitemap" href="/sitemap-index.xml" />
</head>
<body class="bg-zinc-950 text-zinc-100 min-h-screen">
  <header class="border-b border-zinc-800 px-6 py-4">
    <a href="/" class="text-xl font-bold text-white">Util<span class="text-indigo-400">Boxes</span></a>
    <span class="ml-3 text-sm text-zinc-400">Herramientas gratuitas para LatAm</span>
  </header>
  <main class="max-w-6xl mx-auto px-6 py-10">
    <slot />
  </main>
  <footer class="border-t border-zinc-800 px-6 py-6 text-center text-sm text-zinc-500 mt-20">
    © 2026 UtilBoxes · <a href="/privacidad" class="hover:text-zinc-300">Privacidad</a>
  </footer>
</body>
</html>
