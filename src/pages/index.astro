---
import Layout from '../components/Layout.astro';
const tools = [
  { title: 'Calculadora de IVA', description: 'Calcula el IVA de Ecuador, México, Colombia y más países LatAm.', href: '/herramientas/calculadora-iva', emoji: '🧮' },
  { title: 'Generador de Contraseñas', description: 'Genera contraseñas seguras y aleatorias al instante.', href: '/herramientas/generador-password', emoji: '🔐' },
  { title: 'Calculadora Freelance', description: 'Calcula tu precio por hora ideal según tus gastos y meta de ingresos.', href: '/herramientas/precio-freelance', emoji: '💼' },
];
---
<Layout>
  <div class="text-center mb-12">
    <h1 class="text-4xl font-bold text-white mb-4">Herramientas gratuitas para <span class="text-indigo-400">LatAm</span></h1>
    <p class="text-zinc-400 text-lg">Calculadoras, generadores y utilidades para emprendedores y freelancers.</p>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {tools.map(t => (
      <a href={t.href} class="block p-5 rounded-xl border border-zinc-800 bg-zinc-900 hover:border-indigo-500 hover:bg-zinc-800 transition-all group">
        <div class="text-3xl mb-3">{t.emoji}</div>
        <h2 class="font-semibold text-white group-hover:text-indigo-400 transition-colors">{t.title}</h2>
        <p class="mt-1 text-sm text-zinc-400">{t.description}</p>
      </a>
    ))}
  </div>
  <p class="text-center text-zinc-500 mt-12 text-sm">Más herramientas próximamente...</p>
</Layout>
