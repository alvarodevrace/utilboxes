---
import Layout from '../../components/Layout.astro';

const title = 'Calculadora Porcentaje 2026 | UtilBoxes';
const description = 'Calculadora porcentaje para sacar x de y, descuentos, aumentos, diferencia porcentual y regla de tres simple.';
---
<Layout {title} {description}>
  <section class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_340px]">
    <div>
      <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-emerald-300">Calculo comercial</p>
      <h1 class="mb-4 text-4xl font-bold text-white">Calculadora de porcentaje</h1>
      <p class="mb-8 max-w-2xl text-zinc-400">Resuelve cuatro casos comunes de porcentaje para precios, descuentos, variacion y calculo proporcional.</p>
      <div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6">
        <div class="grid gap-4 sm:grid-cols-2">
          <label class="block text-sm text-zinc-300 sm:col-span-2">
            Modo
            <select id="mode" class="mt-2 w-full rounded-md border border-zinc-700 bg-zinc-950 px-3 py-3 text-white">
              <option value="part">x% de y</option>
              <option value="change">Aumento o descuento %</option>
              <option value="difference">Diferencia porcentual</option>
              <option value="rule">Regla de tres simple</option>
            </select>
          </label>
          <label class="block text-sm text-zinc-300">
            Valor A
            <input id="valueA" type="number" step="0.01" value="15" class="mt-2 w-full rounded-md border border-zinc-700 bg-zinc-950 px-3 py-3 text-white" />
          </label>
          <label class="block text-sm text-zinc-300">
            Valor B
            <input id="valueB" type="number" step="0.01" value="200" class="mt-2 w-full rounded-md border border-zinc-700 bg-zinc-950 px-3 py-3 text-white" />
          </label>
          <label class="block text-sm text-zinc-300">
            Valor C
            <input id="valueC" type="number" step="0.01" value="250" class="mt-2 w-full rounded-md border border-zinc-700 bg-zinc-950 px-3 py-3 text-white" />
          </label>
          <label class="block text-sm text-zinc-300">
            Tipo cambio
            <select id="changeType" class="mt-2 w-full rounded-md border border-zinc-700 bg-zinc-950 px-3 py-3 text-white">
              <option value="increase">Aumento</option>
              <option value="decrease">Descuento</option>
            </select>
          </label>
        </div>
      </div>
      <div class="mt-6 rounded-2xl border border-emerald-500/20 bg-emerald-500/5 p-4 text-sm text-zinc-300">
        <p id="modeHelp">Modo `x% de y`: A = porcentaje, B = base.</p>
      </div>
    </div>
    <aside class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6">
      <h2 class="mb-4 text-lg font-semibold text-white">Resultado</h2>
      <p id="resultNumber" class="text-4xl font-bold text-emerald-300">0</p>
      <p id="resultLabel" class="mt-3 text-zinc-300"></p>
    </aside>
  </section>
  <script>
    const mode = document.querySelector('#mode');
    const valueA = document.querySelector('#valueA');
    const valueB = document.querySelector('#valueB');
    const valueC = document.querySelector('#valueC');
    const changeType = document.querySelector('#changeType');
    const resultNumber = document.querySelector('#resultNumber');
    const resultLabel = document.querySelector('#resultLabel');
    const modeHelp = document.querySelector('#modeHelp');

    function formatNumber(value) {
      return Number.isFinite(value) ? value.toLocaleString('es-EC', { maximumFractionDigits: 4 }) : '0';
    }

    function calculate() {
      const a = Number(valueA.value) || 0;
      const b = Number(valueB.value) || 0;
      const c = Number(valueC.value) || 0;
      let result = 0;
      let label = '';
      let help = '';

      if (mode.value === 'part') {
        result = (a / 100) * b;
        label = `${a}% de ${b}`;
        help = 'Modo `x% de y`: A = porcentaje, B = base.';
      }

      if (mode.value === 'change') {
        const change = (a / 100) * b;
        result = changeType.value === 'increase' ? b + change : b - change;
        label = `${changeType.value === 'increase' ? 'Aumento' : 'Descuento'} de ${a}% sobre ${b}`;
        help = 'Modo cambio: A = porcentaje, B = valor base.';
      }

      if (mode.value === 'difference') {
        result = b !== 0 ? ((c - b) / b) * 100 : 0;
        label = `Variacion de ${b} a ${c}`;
        help = 'Modo diferencia: B = valor inicial, C = valor final.';
      }

      if (mode.value === 'rule') {
        result = a !== 0 ? (b * c) / a : 0;
        label = `Si ${a} equivale a ${b}, entonces ${c} equivale a`;
        help = 'Regla de tres: A se relaciona con B. C busca equivalente.';
      }

      resultNumber.textContent = formatNumber(result);
      resultLabel.textContent = label;
      modeHelp.textContent = help;
    }

    [mode, valueA, valueB, valueC, changeType].forEach((element) => element.addEventListener('input', calculate));
    calculate();
  </script>
</Layout>
