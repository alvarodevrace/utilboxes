---
import Layout from '../../components/Layout.astro';
const title = 'Calculadora IVA LatAm 2026 | UtilBoxes';
const description = 'Calculadora IVA para obtener neto, impuesto y total por pais LatAm gratis, rapida y sin registro.';
---
<Layout {title} {description}>
  <section class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_320px]">
    <div>
      <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-emerald-300">Impuestos LatAm</p>
      <h1 class="mb-4 text-4xl font-bold text-white">Calculadora IVA LatAm</h1>
      <p class="mb-8 max-w-2xl text-zinc-400">Calcula precio neto, IVA y total con tasas comunes de Latinoamerica.</p>
      <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-6">
        <div class="grid gap-4 sm:grid-cols-2">
          <label class="block text-sm text-zinc-300">
            Pais
            <select id="country" class="mt-2 w-full rounded-md border border-zinc-700 bg-zinc-950 px-3 py-3 text-white">
              <option value="12">Ecuador - 12%</option>
              <option value="16">Mexico - 16%</option>
              <option value="19">Colombia - 19%</option>
              <option value="18">Peru - 18%</option>
              <option value="19">Chile - 19%</option>
              <option value="21">Argentina - 21%</option>
              <option value="22">Uruguay - 22%</option>
            </select>
          </label>
          <label class="block text-sm text-zinc-300">
            Monto
            <input id="amount" type="number" min="0" step="0.01" value="100" class="mt-2 w-full rounded-md border border-zinc-700 bg-zinc-950 px-3 py-3 text-white" />
          </label>
          <label class="block text-sm text-zinc-300">
            Tipo de monto
            <select id="mode" class="mt-2 w-full rounded-md border border-zinc-700 bg-zinc-950 px-3 py-3 text-white">
              <option value="net">Monto sin IVA</option>
              <option value="gross">Monto con IVA incluido</option>
            </select>
          </label>
          <label class="block text-sm text-zinc-300">
            Tasa personalizada
            <input id="rate" type="number" min="0" step="0.01" class="mt-2 w-full rounded-md border border-zinc-700 bg-zinc-950 px-3 py-3 text-white" />
          </label>
        </div>
      </div>
    </div>
    <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-6">
      <h2 class="mb-4 text-lg font-semibold text-white">Resultado</h2>
      <dl class="space-y-4">
        <div class="flex justify-between gap-4 border-b border-zinc-800 pb-3">
          <dt class="text-zinc-400">Neto</dt>
          <dd id="net" class="font-semibold text-white">$0.00</dd>
        </div>
        <div class="flex justify-between gap-4 border-b border-zinc-800 pb-3">
          <dt class="text-zinc-400">IVA</dt>
          <dd id="tax" class="font-semibold text-white">$0.00</dd>
        </div>
        <div class="flex justify-between gap-4">
          <dt class="text-zinc-400">Total</dt>
          <dd id="gross" class="text-xl font-bold text-emerald-300">$0.00</dd>
        </div>
      </dl>
    </div>
  </section>
  <script>
    const amount = document.querySelector('#amount');
    const country = document.querySelector('#country');
    const mode = document.querySelector('#mode');
    const rate = document.querySelector('#rate');
    const net = document.querySelector('#net');
    const tax = document.querySelector('#tax');
    const gross = document.querySelector('#gross');
    const money = new Intl.NumberFormat('es-EC', { style: 'currency', currency: 'USD' });

    function calculate() {
      const input = Number(amount.value) || 0;
      const activeRate = Number(rate.value || country.value) / 100;
      const netValue = mode.value === 'gross' ? input / (1 + activeRate) : input;
      const taxValue = netValue * activeRate;
      const grossValue = netValue + taxValue;
      net.textContent = money.format(netValue);
      tax.textContent = money.format(taxValue);
      gross.textContent = money.format(grossValue);
    }

    [amount, country, mode, rate].forEach((inputEl) => inputEl.addEventListener('input', calculate));
    country.addEventListener('change', () => {
      rate.value = country.value;
      calculate();
    });
    rate.value = country.value;
    calculate();
  </script>
</Layout>
  </div>
</Layout>
