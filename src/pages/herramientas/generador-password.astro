---
import Layout from '../../components/Layout.astro';
const title = 'Generador Password 2026 | UtilBoxes';
const description = 'Generador password seguro con longitud, simbolos, numeros y copia rapida gratis desde el navegador.';
---
<Layout {title} {description}>
  <section class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_340px]">
    <div>
      <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-emerald-300">Seguridad client-side</p>
      <h1 class="mb-4 text-4xl font-bold text-white">Generador de passwords</h1>
      <p class="mb-8 max-w-2xl text-zinc-400">Genera passwords aleatorias en tu navegador. Nada sale del dispositivo.</p>
      <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-6">
        <label class="block text-sm text-zinc-300">
          Longitud: <span id="lengthValue" class="font-semibold text-white">18</span>
          <input id="length" type="range" min="8" max="64" value="18" class="mt-3 w-full accent-emerald-400" />
        </label>
        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          <label class="flex items-center gap-3 rounded-md border border-zinc-800 p-3 text-sm text-zinc-300"><input id="upper" type="checkbox" checked class="accent-emerald-400" /> Mayusculas</label>
          <label class="flex items-center gap-3 rounded-md border border-zinc-800 p-3 text-sm text-zinc-300"><input id="lower" type="checkbox" checked class="accent-emerald-400" /> Minusculas</label>
          <label class="flex items-center gap-3 rounded-md border border-zinc-800 p-3 text-sm text-zinc-300"><input id="numbers" type="checkbox" checked class="accent-emerald-400" /> Numeros</label>
          <label class="flex items-center gap-3 rounded-md border border-zinc-800 p-3 text-sm text-zinc-300"><input id="symbols" type="checkbox" checked class="accent-emerald-400" /> Simbolos</label>
        </div>
        <button id="generate" class="mt-6 rounded-md bg-emerald-400 px-4 py-3 font-semibold text-zinc-950 hover:bg-emerald-300">Generar password</button>
      </div>
    </div>
    <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-6">
      <h2 class="mb-4 text-lg font-semibold text-white">Password</h2>
      <textarea id="password" readonly rows="5" class="w-full resize-none rounded-md border border-zinc-700 bg-zinc-950 p-3 font-mono text-sm text-emerald-300"></textarea>
      <button id="copy" class="mt-4 w-full rounded-md border border-zinc-700 px-4 py-3 font-semibold text-white hover:border-emerald-400">Copiar</button>
      <p id="status" class="mt-3 min-h-5 text-sm text-zinc-500"></p>
    </div>
  </section>
  <script>
    const chars = {
      upper: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ',
      lower: 'abcdefghijklmnopqrstuvwxyz',
      numbers: '0123456789',
      symbols: '!@#$%^&*()-_=+[]{};:,.?/',
    };
    const length = document.querySelector('#length');
    const lengthValue = document.querySelector('#lengthValue');
    const password = document.querySelector('#password');
    const status = document.querySelector('#status');

    function selectedCharset() {
      return Object.keys(chars)
        .filter((key) => document.querySelector(`#${key}`).checked)
        .map((key) => chars[key])
        .join('');
    }

    function generatePassword() {
      const charset = selectedCharset() || chars.lower;
      const bytes = new Uint32Array(Number(length.value));
      crypto.getRandomValues(bytes);
      password.value = Array.from(bytes, (value) => charset[value % charset.length]).join('');
      lengthValue.textContent = length.value;
      status.textContent = '';
    }

    document.querySelector('#generate').addEventListener('click', generatePassword);
    document.querySelector('#copy').addEventListener('click', async () => {
      await navigator.clipboard.writeText(password.value);
      status.textContent = 'Copiado.';
    });
    document.querySelectorAll('input').forEach((inputEl) => inputEl.addEventListener('input', generatePassword));
    generatePassword();
  </script>
</Layout>
